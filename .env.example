# =============================================================================
# Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database (REQUIRED)
# -----------------------------------------------------------------------------
# PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
#
# Examples:
#   Local:    postgresql://postgres:postgres@localhost:5432/kanban_db
#   Docker:   postgresql://postgres:postgres@localhost:5432/kanban_db
#   Supabase: postgresql://postgres.<ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#   Neon:     postgresql://<user>:<password>@<endpoint>.neon.tech/kanban_db?sslmode=require
#
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kanban_db

# -----------------------------------------------------------------------------
# GitHub Token (OPTIONAL but recommended)
# -----------------------------------------------------------------------------
# A GitHub Personal Access Token (classic) with "repo" scope.
#
# Without token:
#   - Anonymous access, 60 API requests/hour
#   - Public repos only, read-only mode (2 columns)
#
# With token:
#   - 5,000 API requests/hour
#   - Private repo access
#   - Read-write mode for repos you have push access to (3 columns + drag sync)
#
# How to create:
#   1. Go to https://github.com/settings/tokens
#   2. Click "Generate new token (classic)"
#   3. Check the "repo" scope (Full control of private repositories)
#   4. Generate and copy the token (starts with ghp_)
#
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# Server Configuration (OPTIONAL)
# -----------------------------------------------------------------------------
# Backend API server port. Default: 3001
# The frontend dev server (Vite) automatically proxies /api/* to this port.
PORT=3001

# Session secret for cookie signing. Use a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-string
